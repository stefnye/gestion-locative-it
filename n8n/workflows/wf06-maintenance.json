{
  "name": "WF-06 : Demande maintenance locataire",
  "nodes": [
    {
      "parameters": {},
      "name": "Formulaire / Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "notes": "Formulaire n8n ou NocoDB form pour signalement locataire"
    },
    {
      "parameters": {
        "url": "={{ $env.NOCODB_URL }}/api/v1/db/data/noco/{{ $env.NOCODB_PROJECT }}/maintenance",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "name": "Créer entrée NocoDB maintenance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.VIKUNJA_URL }}/api/v1/projects/{{ $env.VIKUNJA_PROJECT_ID }}/tasks",
        "method": "PUT",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "name": "Créer tâche Vikunja",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 200],
      "notes": "Crée une tâche dans le kanban maintenance Vikunja"
    },
    {
      "parameters": {},
      "name": "Notification Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [680, 400],
      "notes": "Alerte propriétaire de la nouvelle demande de maintenance"
    }
  ],
  "connections": {
    "Formulaire / Webhook": { "main": [[{ "node": "Créer entrée NocoDB maintenance", "type": "main", "index": 0 }]] },
    "Créer entrée NocoDB maintenance": { "main": [[{ "node": "Créer tâche Vikunja", "type": "main", "index": 0 }, { "node": "Notification Telegram", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "gestion-locative" }]
}
