{
  "name": "WF-04 : Rappels échéances",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 9 * * 1" }]
        }
      },
      "name": "Cron hebdo (lundi 9h)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.NOCODB_URL }}/api/v1/db/data/noco/{{ $env.NOCODB_PROJECT }}/echeances",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "name": "Requête échéances J+30",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300],
      "notes": "WHERE date_echeance BETWEEN today AND today+30 AND statut = 'a_venir'"
    },
    {
      "parameters": {},
      "name": "Formater message Telegram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "notes": "Construit un message groupé avec la liste des échéances + rappel Nordigen si < 90j"
    },
    {
      "parameters": {},
      "name": "Envoyer Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [900, 300]
    }
  ],
  "connections": {
    "Cron hebdo (lundi 9h)": { "main": [[{ "node": "Requête échéances J+30", "type": "main", "index": 0 }]] },
    "Requête échéances J+30": { "main": [[{ "node": "Formater message Telegram", "type": "main", "index": 0 }]] },
    "Formater message Telegram": { "main": [[{ "node": "Envoyer Telegram", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "gestion-locative" }]
}
