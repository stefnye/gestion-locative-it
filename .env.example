# =============================================================================
# Gestion Locative — Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=gestion
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# --- Database names ---
FIREFLY_DB_NAME=firefly
PAPERLESS_DB_NAME=paperless
NOCODB_DB_NAME=nocodb
VIKUNJA_DB_NAME=vikunja

# --- Firefly III ---
FIREFLY_III_ACCESS_TOKEN=CHANGE_ME_firefly_token
APP_KEY=CHANGE_ME_32_char_app_key

# --- Firefly Data Importer (Nordigen / GoCardless) ---
NORDIGEN_ID=CHANGE_ME_nordigen_id
NORDIGEN_KEY=CHANGE_ME_nordigen_key

# --- Paperless-ngx ---
PAPERLESS_SECRET_KEY=CHANGE_ME_paperless_secret
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=CHANGE_ME_paperless_admin_password

# --- NocoDB ---
NOCODB_JWT_SECRET=CHANGE_ME_nocodb_jwt_secret

# --- Vikunja ---
VIKUNJA_JWT_SECRET=CHANGE_ME_vikunja_jwt_secret

# --- n8n (already deployed separately) ---
N8N_API_KEY=CHANGE_ME_n8n_api_key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=CHANGE_ME_telegram_bot_token
TELEGRAM_CHAT_ID=CHANGE_ME_telegram_chat_id
